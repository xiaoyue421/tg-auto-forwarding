# Web dashboard password. Default is admin.
TG_DASHBOARD_PASSWORD=admin

# Optional Docker build settings. Useful when Docker Hub or PyPI is unstable.
PYTHON_BASE_IMAGE=python:3.12-slim
PIP_INDEX_URL=
PIP_TRUSTED_HOST=

# Simple mode: fill these key values and run.
TG_API_ID=
TG_API_HASH=
TG_SESSION_STRING=
TG_BOT_TOKEN=
# Multiple bot tokens are supported, e.g. token_1,token_2,token_3
TG_FORWARD_STRATEGY=parallel
TG_RATE_LIMIT_PROTECTION=false
TG_RATE_LIMIT_DELAY_SECONDS=1.2
TG_STARTUP_NOTIFY_ENABLED=false
TG_STARTUP_NOTIFY_MESSAGE=
TG_SOURCE_CHAT=@source_channel
TG_TARGET_CHATS=@target_channel_1,@target_channel_2
TG_BOT_TARGET_CHATS=

# Optional simple mode settings
TG_WORKER_NAME=main
TG_INCLUDE_EDITS=false
TG_FORWARD_OWN_MESSAGES=false
TG_KEYWORDS_ANY=
TG_KEYWORDS_ALL=
TG_BLOCK_KEYWORDS=
TG_MEDIA_ONLY=false
TG_TEXT_ONLY=false
TG_CONTENT_MATCH_MODE=all
TG_CASE_SENSITIVE=false

# Web dashboard multi-rule mode. Usually managed automatically by the web UI.
TG_RULES_JSON=

# Optional session file mode
TG_SESSION_FILE=

# Optional proxy
TG_PROXY_TYPE=socks5
TG_PROXY_HOST=
TG_PROXY_PORT=
TG_PROXY_USER=
TG_PROXY_PASSWORD=
TG_PROXY_RDNS=true

# Optional supervisor tuning
TG_CHECK_INTERVAL=5
TG_RESTART_DELAY=3
TG_STOP_TIMEOUT=10
TG_WORKER_MAX_RESTARTS=5
TG_WORKER_FAILURE_RESET_SECONDS=60
TG_QUEUE_DB_PATH=

# Advanced YAML mode can still use extra worker-specific variables if you want.
SOURCE_NEWS_SESSION=
SOURCE_MEDIA_SESSION=
