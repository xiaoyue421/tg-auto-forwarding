# TelegramForwarder example config
# 使用方式：
# 1. 复制本文件为 .env
# 2. 填写 API ID / API HASH
# 3. 生成并填入 TG_SESSION_STRING，或改用 TG_SESSION_FILE
# 4. 按需填写 Bot、规则和代理
#
# 注意：每行必须是「变量名=值」或注释（#）。不要单独粘贴 URL/正则（如 hdhive.com/resource/…），
# 否则会触发 dotenv 解析错误；若已误加，请删掉或改成注释行。

# Docker Compose（可选；与下方配置可共用本文件）
# 生产：docker compose up -d 后控制台 http://127.0.0.1:8810（compose 内固定 8810→8080）。
# 仅当需要「开发容器」时设为 true（会多起 tg-forwarder-dev，默认主机端口 8081）
# COMPOSE_PROFILES=true
# TG_DASHBOARD_DEV_PORT=8081

# 控制台密码
TG_DASHBOARD_PASSWORD=admin

# Web 会话（登录后 HTTP-only Cookie，默认 12 小时）
TG_DASHBOARD_SESSION_TTL_SECONDS=43200
# 在 HTTPS 反向代理后部署时设为 true，使 Cookie 带 Secure
TG_DASHBOARD_COOKIE_SECURE=false
# 登录失败限速（滑动窗口内允许失败次数 / 窗口秒数）
TG_DASHBOARD_LOGIN_MAX_ATTEMPTS=12
TG_DASHBOARD_LOGIN_WINDOW_SECONDS=300
# 跨域访问 API 时填写来源列表，英文逗号分隔；留空则不启用 CORS（推荐同源访问）
# 示例：https://dash.example.com  或  *（不推荐与 Cookie 登录同时使用）
TG_DASHBOARD_CORS_ORIGINS=

# Telegram API
TG_API_ID=
TG_API_HASH=

# 二选一：优先使用 TG_SESSION_STRING
TG_SESSION_STRING=
# TG_SESSION_FILE=./sessions/main.session

# Bot Token
# 支持单个或多个，多个请用英文逗号分隔
TG_BOT_TOKEN=

# 全局发送策略
# 可选：parallel / account_first / bot_first / account_only / bot_only
TG_FORWARD_STRATEGY=parallel

# 全局限流
TG_RATE_LIMIT_PROTECTION=false
TG_RATE_LIMIT_DELAY_SECONDS=1.2

# 启动通知
TG_STARTUP_NOTIFY_ENABLED=false
# 留空则使用系统默认启动通知文案
TG_STARTUP_NOTIFY_MESSAGE=

# 搜索模式
# 当前只支持 fast
TG_SEARCH_DEFAULT_MODE=fast

# HDHive（https://hdhive.com/）站点 — 亦可在控制台「站点设置」中配置
# HDHIVE_CHECKIN_METHOD=api_key（Premium，X-API-Key）或 cookie（非 Premium，Next Server Action）
HDHIVE_CHECKIN_METHOD=api_key
# Premium：请求头 X-API-Key
HDHIVE_API_KEY=
# 非 Premium：浏览器里复制的 Cookie（含 token=…）、Next-Action、Next-Router-State-Tree（站点更新后可能需重填）
# 同一 Cookie 亦用于「转发规则 → 二次检测 → 解析 HDHive 资源页」拉取 /resource/… 中的直链（需勾选规则内对应选项）
HDHIVE_COOKIE=
HDHIVE_NEXT_ACTION=
HDHIVE_NEXT_ROUTER_STATE_TREE=
HDHIVE_CHECKIN_ENABLED=false
# true = POST JSON {"is_gambler": true} 博弈模式
HDHIVE_CHECKIN_GAMBLER=false
# true = 签到走下方 TG_PROXY_* 单代理（与 Telegram 共用；不使用 TG_PROXY_URLS 多代理列表）
HDHIVE_CHECKIN_USE_PROXY=false

# 单代理配置
TG_PROXY_TYPE=socks5
TG_PROXY_HOST=
TG_PROXY_PORT=
TG_PROXY_USER=
TG_PROXY_PASSWORD=
TG_PROXY_RDNS=true

# 多代理配置（可选）
# 一行一个，或逗号分隔，例如：
# TG_PROXY_URLS=socks5://127.0.0.1:7890,socks5://127.0.0.1:7891
TG_PROXY_URLS=

# 单规则简化模式
# 如果你主要通过 Web 控制台管理多规则，可以先保留这些基础值
TG_SOURCE_CHAT=@source_channel
TG_TARGET_CHATS=@target_channel_1,@target_channel_2
TG_BOT_TARGET_CHATS=
TG_WORKER_NAME=main
TG_INCLUDE_EDITS=false
TG_FORWARD_OWN_MESSAGES=false

# 过滤条件
TG_KEYWORDS_ANY=
TG_KEYWORDS_ALL=
TG_BLOCK_KEYWORDS=

# 正则条件
# 多个正则可使用换行；在 .env 中保存时建议用 Web 控制台维护
TG_REGEX_ANY=
TG_REGEX_ALL=
TG_REGEX_BLOCK=

# 多 Bot 依次登录时间隔（秒），减轻 Telegram FloodWait（ImportBotAuthorization）
TG_BOT_POOL_START_STAGGER_SECONDS=3.5
# 遇到 FloodWait 时最多睡眠多少秒再重试一次同一代理（0=不等待，直接跳过该 bot；若设为 700 可覆盖约 11 分钟档位的限流）
TG_BOT_FLOODWAIT_MAX_SLEEP_SECONDS=0

# 已废弃：保存配置时会写空字符串，请勿再使用
TG_RESOURCE_PRESETS=

# 媒体 / 文本匹配
TG_MEDIA_ONLY=false
TG_TEXT_ONLY=false
# 可选：all / any
TG_CONTENT_MATCH_MODE=all
TG_CASE_SENSITIVE=false

# 多规则模式
# 由 Web 控制台保存后自动写入，通常不建议手动编辑
TG_RULES_JSON=

# Worker 去重缓存上限（每条源频道）
TG_WORKER_RECENT_SEEN_CACHE_LIMIT=4096

# 队列调度器空闲轮询间隔（秒，0.05–60）
TG_DISPATCH_POLL_INTERVAL_SECONDS=0.25

# Supervisor / worker 运行参数
TG_CHECK_INTERVAL=5
TG_RESTART_DELAY=3
TG_STOP_TIMEOUT=10
TG_WORKER_MAX_RESTARTS=5
TG_WORKER_FAILURE_RESET_SECONDS=60

# 队列数据库路径（若出现 database disk image is malformed，多为卷未同步或异常断电导致文件损坏；
# 可先备份再删除该文件重建空队列，或用 sqlite3 旧库 ".recover" 导出到新文件后改路径）
TG_QUEUE_DB_PATH=/data/tg_forwarder_queue.sqlite3

# 扩展模块目录（网页「导入模块」写入此处；Docker compose 已默认 /data/tg_modules，可改本机路径）
# TG_MODULES_PATH=/data/tg_modules
